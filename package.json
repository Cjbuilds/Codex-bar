{
  "name": "codex-bar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:assets": "node scripts/generate-demo-assets.mjs",
    "check:assets": "node scripts/generate-demo-assets.mjs --check",
    "check:release-tag": "node scripts/check-release-tag.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "audit:privacy": "node scripts/audit-privacy.mjs",
    "demo:live": "node scripts/demo-live.mjs",
    "doctor": "node scripts/doctor.mjs",
    "install:local": "node scripts/install-local.mjs",
    "perf:sample": "node scripts/perf-sample.mjs",
    "smoke:state": "node scripts/smoke-state.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:swift": "swift test --package-path plugins/codex-status-bar/app",
    "build:app": "node plugins/codex-status-bar/scripts/package-app.mjs",
    "package:release": "node scripts/package-release.mjs",
    "verify": "npm run check:assets && npm run validate:plugin && npm run test && npm run smoke:state && npm run test:swift && npm run build:app && npm run doctor && npm run package:release"
  }
}
