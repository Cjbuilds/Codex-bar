{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" SessionStart",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" UserPromptSubmit",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" PreToolUse",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" PermissionRequest",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" PostToolUse",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" PreCompact",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" PostCompact",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" SubagentStart",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" SubagentStop",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/hook.mjs\" Stop",
            "timeout": 10,
            "statusMessage": "Updating Codex Status Bar"
          }
        ]
      }
    ]
  }
}
